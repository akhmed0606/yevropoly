    <style>
        .warranty-hero { padding: 120px 20px 60px 20px; background-color: var(--navy); color: white; text-align: center; }
        .intro-text { max-width: 800px; margin: 0 auto; padding: 50px 20px 20px 20px; font-size: 1.1rem; line-height: 1.7; color: #334155; text-align: center; }
        
        .warranty-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px; max-width: 1000px; margin: 40px auto; padding: 0 20px; }
        .warranty-card { background: white; border: 1px solid var(--border); border-radius: 8px; padding: 40px 30px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); display: flex; flex-direction: column; }
        .warranty-badge { display: inline-block; background: #e0f2fe; color: #0284c7; font-weight: 700; padding: 8px 16px; border-radius: 50px; margin-bottom: 20px; font-size: 0.9rem; align-self: flex-start; }
        .warranty-card h2 { font-size: 1.5rem; color: var(--navy); margin-bottom: 15px; }
        
        .condition-list { list-style: none; padding: 0; margin-bottom: 30px; flex-grow: 1; }
        .condition-list li { position: relative; padding-left: 28px; margin-bottom: 12px; color: var(--text-light); font-size: 0.95rem; line-height: 1.5; }
        .condition-list li::before { content: "\f058"; font-family: "Font Awesome 6 Free"; font-weight: 900; position: absolute; left: 0; top: 2px; color: #10b981; font-size: 1.1rem; }
        
        .btn-download { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; text-align: center; background-color: #f1f5f9; color: var(--navy); border: 1px solid var(--border); font-weight: 600; padding: 14px 20px; border-radius: 6px; transition: all 0.3s ease; text-decoration: none; }
        .btn-download:hover { background-color: var(--navy); color: white; border-color: var(--navy); }
        
        .important-notes { max-width: 1000px; margin: 40px auto 60px auto; background-color: #fffbeb; border-left: 4px solid #f59e0b; padding: 30px; border-radius: 0 8px 8px 0; }
        .important-notes h3 { color: #b45309; margin-top: 0; margin-bottom: 15px; font-size: 1.2rem; }
        .important-notes p { color: #78350f; margin-bottom: 10px; font-size: 0.95rem; }
        .important-notes p:last-child { margin-bottom: 0; }

        .contact-claims { max-width: 1000px; margin: 0 auto 60px auto; text-align: center; padding: 40px 20px; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border); }

        @media (max-width: 768px) {
            .warranty-hero { padding: 100px 20px 40px 20px; }
            .warranty-hero h1 { font-size: 2.2rem !important; }
            .warranty-card { padding: 30px 20px; }
        }
